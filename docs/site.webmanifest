      "label": "MiruShin desktop player"
    },
    {
      "src": "assets/imgs/mobile_tmdb.png",
      "sizes": "1320x2868",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "MiruShin mobile discovery"
    },
    {
      "src": "assets/imgs/mobile_player.png",
      "sizes": "1320x2868",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "MiruShin mobile player"
    }
  ],
  "shortcuts": [
    {
      "name": "Downloads",
