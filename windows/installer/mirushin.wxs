<?xml version="1.0" encoding="UTF-8"?>
<!--
  MiruShin Windows MSI installer (WiX v5).

  Dual-scope: the WixUI_Advanced dialog set lets the user choose
  "Install just for you" (per-user, no UAC, under %LocalAppData%) or
  "Install for all users" (per-machine, under Program Files, elevates).

  Build from the project root (see .github/workflows/build-windows.yml):
    wix extension add -g WixToolset.UI.wixext/5.0.2
    wix build -arch x64 -ext WixToolset.UI.wixext `
      -d Version=X.Y.Z `
      -d SourceDir=<abs-path-to-Release-folder> `
      -d IconFile=windows\runner\resources\app_icon.ico `
      -d LicenseRtf=windows\installer\license.rtf `
      -o MiruShin-windows-vX.Y.Z-setup.msi `
      windows\installer\mirushin.wxs
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="MiruShin"
           Manufacturer="emp0ry"
           Version="$(var.Version)"
           Scope="perUserOrMachine"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">

    <!-- Block downgrades and replace older versions in place. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- WixUI_Advanced: the AdvancedWelcomeEulaDlg's "Advanced" button leads to
         InstallScopeDlg, where the user picks per-user or per-machine. The UI's
         built-in custom actions set APPLICATIONFOLDER to %LocalAppData% (per
         user) or Program Files (all users) based on WixAppFolder. -->
    <Property Id="ApplicationFolderName" Value="MiruShin" />
    <Property Id="WixAppFolder" Value="WixPerUserFolder" />
    <ui:WixUI Id="WixUI_Advanced" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />

    <!-- Default (all-users) location; redirected for per-user by the UI. -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="APPLICATIONFOLDER" Name="!(bind.Property.ApplicationFolderName)" />
    </StandardDirectory>
    <!-- ProgramMenuFolder / DesktopFolder resolve per-user or all-users to
         match the chosen scope. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="MiruShin" />
    </StandardDirectory>

    <Feature Id="Main" Title="MiruShin" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="AppShortcuts" />
    </Feature>

    <!-- Add/Remove Programs metadata. -->
    <Icon Id="AppIcon.ico" SourceFile="$(var.IconFile)" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/emp0ry/MiruShin" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/emp0ry/MiruShin" />
  </Package>

  <!-- Harvest the entire Flutter Release folder (exe, DLLs, data\, plugins). -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="APPLICATIONFOLDER">
      <Files Include="$(var.SourceDir)\**" />
    </ComponentGroup>
  </Fragment>

  <!-- Start Menu + Desktop shortcuts. HKMU maps to HKCU or HKLM to match the
       chosen install scope. -->
  <Fragment>
    <StandardDirectory Id="DesktopFolder" />
    <Component Id="AppShortcuts" Directory="AppShortcutFolder" Guid="*">
      <Shortcut Id="StartMenuShortcut"
                Name="MiruShin"
                Target="[APPLICATIONFOLDER]mirushin.exe"
                WorkingDirectory="APPLICATIONFOLDER"
                Icon="AppIcon.ico" />
      <Shortcut Id="DesktopShortcut"
                Directory="DesktopFolder"
                Name="MiruShin"
                Target="[APPLICATIONFOLDER]mirushin.exe"
                WorkingDirectory="APPLICATIONFOLDER"
                Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
      <RegistryValue Root="HKMU"
                     Key="Software\emp0ry\MiruShin"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>
